# Checked-in template for the local infra-local stack's API .env.
#
# stack-up.sh copies this to apps/api/.env on first run when that file is
# missing (apps/api/.env is gitignored — in prod it holds real secrets, so it
# must never be committed). Every value below is a deterministic LOCAL-ONLY
# placeholder that pairs with the L1 boxes infra-local brings up; none is a
# real secret. Edit apps/api/.env (not this file) for personal local tweaks.
#
# All hostnames are 127.0.0.1 — the API runs as a HOST process, not in a box.

NODE_ENV=development
ENVIRONMENT=local
PORT=3001
APP_URL=http://localhost:3001
APP_MODE=api
APP_ROLE=all
RUN_MIGRATIONS=true

# Disable optional integrations
NOTIFICATION_GATEWAY_DISABLED=true
SKIP_CONNECTIONS=false
MAINTENANCE_MODE=false
DISABLE_CRON_JOBS=false

# Postgres (infra-local: pg on 25432, user/db both "boxlite", trust auth)
DB_HOST=127.0.0.1
DB_PORT=25432
DB_USERNAME=boxlite
DB_PASSWORD=boxlite
DB_DATABASE=boxlite

# Redis (infra-local: 26379)
REDIS_HOST=127.0.0.1
REDIS_PORT=26379

# OIDC (Dex via browser-reachable localhost — used both for issuer discovery
# and as the verification authority for incoming JWTs)
OIDC_CLIENT_ID=boxlite
OIDC_ISSUER_BASE_URL=http://localhost:25556/dex
OIDC_AUDIENCE=boxlite
PUBLIC_OIDC_DOMAIN=http://localhost:25556/dex

# Dashboard (Vite dev)
DASHBOARD_URL=http://localhost:3000

# MinIO S3 (infra-local: 29000, user/pass "minioadmin")
S3_ENDPOINT=http://127.0.0.1:29000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_DEFAULT_BUCKET=boxlite

# Internal registry (infra-local: 25000)
INTERNAL_REGISTRY_URL=http://127.0.0.1:25000
INTERNAL_REGISTRY_ADMIN=admin
INTERNAL_REGISTRY_PASSWORD=admin
INTERNAL_REGISTRY_PROJECT_ID=boxlite

# Transient registry (same as internal for local dev)
TRANSIENT_REGISTRY_URL=http://127.0.0.1:25000
TRANSIENT_REGISTRY_ADMIN=admin
TRANSIENT_REGISTRY_PASSWORD=admin
TRANSIENT_REGISTRY_PROJECT_ID=boxlite-transient

# Proxy (Caddy)
PROXY_DOMAIN=localhost:28080
PROXY_PROTOCOL=http
PROXY_TEMPLATE_URL=http://{{PORT}}-{{boxId}}.localhost:28080
PROXY_API_KEY=boxlite-proxy-key

# OTEL (infra-local: 24317 gRPC, 24318 HTTP)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:24318

# Audit (disabled for local)
AUDIT_PUBLISH_ENABLED=false
AUDIT_TOOLBOX_REQUESTS_ENABLED=false
AUDIT_CONSOLE_LOG_ENABLED=true

# Pylon (disabled)
PYLON_APP_ID=

# PostHog (disabled)
POSTHOG_API_KEY=
POSTHOG_HOST=

# Admin quotas (generous defaults for local)
ADMIN_TOTAL_CPU_QUOTA=100
ADMIN_TOTAL_MEMORY_QUOTA=200
ADMIN_TOTAL_DISK_QUOTA=500
ADMIN_MAX_CPU_PER_BOX=8
ADMIN_MAX_MEMORY_PER_BOX=16
ADMIN_MAX_DISK_PER_BOX=50
ADMIN_VOLUME_QUOTA=100

# Admin API key (for internal admin endpoints)
ADMIN_API_KEY=local-dev-admin-key

# API key cache TTLs
API_KEY_USER_CACHE_TTL_SECONDS=60
API_KEY_VALIDATION_CACHE_TTL_SECONDS=60

# Runner registration (API auto-creates DB record on boot using these)
DEFAULT_RUNNER_NAME=local-m5
DEFAULT_RUNNER_API_KEY=local-shared-runner-token-aaaa1111
DEFAULT_RUNNER_DOMAIN=127.0.0.1
DEFAULT_RUNNER_API_URL=http://127.0.0.1:3003
DEFAULT_RUNNER_PROXY_URL=http://127.0.0.1:25080
DEFAULT_RUNNER_API_VERSION=2
DEFAULT_RUNNER_CPU=2
DEFAULT_RUNNER_MEMORY=4
DEFAULT_RUNNER_DISK=20

# Encryption (any 32+ char random for local; matches none in prod since this is a fresh local DB)
ENCRYPTION_KEY=local-dev-encryption-key-please-do-not-use-in-prod-aaaa1111
ENCRYPTION_SALT=local-dev-encryption-salt-bbbb2222

LOG_LEVEL=debug

# Internal service tokens (validate() throws if these aren't set)
SSH_GATEWAY_API_KEY=local-ssh-gateway-key-not-used-cccc
LOG_EXECUTIONS=true
